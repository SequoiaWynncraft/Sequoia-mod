{
  "required": true,
  "minVersion": "0.8",
  "package": "org.sequoia.seq.mixins",
  "compatibilityLevel": "JAVA_21",
  "mixins": [
    "MinecraftMixin"
  ],
  "client": [
    "AbstractContainerScreenMixin",
    "ClientPacketListenerMixin",
    "GameRendererMixin",
    "InGameHudMixin",
